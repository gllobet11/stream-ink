{
  "manifest_version": 2,
  "name": "StreamInk – Draw on Screen for Streaming",
  "version": "1.0.0",
  "description": "Draw annotations on any webpage. Visible in OBS window/tab capture.",
  "browser_specific_settings": {
    "gecko": {
      "id": "streamink@gllobet11",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "storage", "tabs", "<all_urls>"],
  "commands": {
    "toggle-draw": {
      "suggested_key": {
        "default": "Alt+D"
      },
      "description": "Toggle drawing mode"
    },
    "clear-canvas": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Clear all drawings"
    }
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "StreamInk – Toggle Drawing (Alt+D)"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
